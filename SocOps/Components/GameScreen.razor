@using SocOps.Models

<div class="flex flex-col min-h-full bg-app">
    <!-- Header -->
    <header class="match-header flex items-center justify-between">
        <button
            @onclick="OnReset"
            class="btn-ghost text-sm px-3 py-1.5 rounded transition-colors">
            Back
        </button>

        <div class="text-center">
            <p class="kicker mb-2">Real Madrid Theme</p>
            <h1 class="font-bold font-display text-ink">Soc Ops</h1>
        </div>

        <img
            src="https://upload.wikimedia.org/wikipedia/en/5/56/Real_Madrid_CF.svg"
            alt="Real Madrid crest"
            class="crest-mini" />
    </header>

    <!-- Instructions -->
    <p class="instruction-chip text-sm">
        Tap a square when someone matches the prompt.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="victory-strip text-sm">
            BINGO! You completed a winning line.
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <div class="board-shell p-3 w-full max-w-md">
            <BingoBoard
                Board="@Board"
                WinningSquareIds="@WinningSquareIds"
                OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
