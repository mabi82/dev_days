@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 checkmark text-xs">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "bingo-square relative flex items-center justify-center p-1 text-center border rounded transition-all duration-150 select-none min-h-[60px] text-xs leading-tight";

        var stateClasses = Square.IsFreeSpace
            ? "square-free"
            : Square.IsMarked
                ? IsWinning
                    ? "square-winning"
                    : "square-marked"
                : "square-default";

        var freeSpaceClasses = Square.IsFreeSpace ? "font-bold text-sm" : string.Empty;

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
