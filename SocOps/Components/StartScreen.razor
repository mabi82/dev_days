<div class="flex flex-col items-center justify-center min-h-full p-6 bg-app">
    <div class="w-full max-w-md text-center">
        <div class="hero-card p-6 mb-6">
            <div class="laurids-badge mx-auto mb-4" aria-hidden="true">L</div>
            <p class="kicker mb-2">Team Laurids Edition</p>
            <h1 class="text-4xl font-bold font-display text-ink mb-2">Laurids Social Bingo</h1>
            <p class="text-lg text-soft">Find kolleger med Laurids-vibes og fuldfoer en linje for at vinde.</p>
        </div>

        <div class="panel-card p-6 mb-8 text-left">
            <h2 class="font-semibold font-display text-ink mb-3">Saadan spiller I</h2>
            <ul class="text-soft text-sm space-y-2">
                <li>Find en kollega der matcher hvert Laurids-spoergsmaal.</li>
                <li>Tryk paa feltet, naar du har et match.</li>
                <li>Fa fem paa stribe for at raabe bingo.</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full btn-primary font-semibold py-4 px-8 rounded-lg text-lg transition-colors">
            Start Laurids Bingo
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
