<div class="fixed inset-0 modal-overlay flex items-center justify-center p-4 z-50">
    <div class="modal-card p-6 max-w-xs w-full text-center shadow-xl animate-[bounce_0.5s_ease-out]">
        <div class="text-5xl mb-4">🏆</div>
        <h2 class="text-3xl font-bold font-display text-red mb-2">BINGO!</h2>
        <p class="modal-copy mb-6">Du ramte Laurids-linjen. Fortsaet og se hvor mange linjer I kan tage.</p>

        <button
            @onclick="OnDismiss"
            class="w-full btn-primary font-semibold py-3 px-6 rounded-lg transition-colors">
            Fortsaet spillet
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
